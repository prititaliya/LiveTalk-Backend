# Copy this file to .env.local and fill in your values

# LiveKit Configuration
# Get these from your LiveKit server dashboard
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your-api-key-here
LIVEKIT_API_SECRET=your-api-secret-here

# STT Provider Configuration
# Speechmatics is the default and recommended provider (supports native diarization)
# Set STT_MODEL to switch between providers: speechmatics, deepgram, assemblyai
STT_MODEL=speechmatics  # Default: speechmatics (recommended)

# Provider-specific API Keys
# REQUIRED: Set SPEECHMATICS_API_KEY for Speechmatics (default provider)
SPEECHMATICS_API_KEY=your-speechmatics-api-key-here
# Optional: Only needed if using Deepgram or AssemblyAI
DEEPGRAM_API_KEY=your-deepgram-api-key-here
ASSEMBLYAI_API_KEY=your-assemblyai-api-key-here

# Redis Configuration
# Option 1: Use Redis URL (for Redis Cloud or custom configurations)
# REDIS_URL=redis://localhost:6379/0
# Option 2: Use individual connection parameters
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# PostgreSQL Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/livetalk

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI Configuration for Chatbot
OPENAI_API_KEY=your-openai-api-key-here
CHATBOT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_STORE_TYPE=memory

# Google Calendar Configuration
# Path to Google Calendar service account credentials JSON file
# This file should be downloaded from Google Cloud Console
# Example: GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=/path/to/credentials.json
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=/Users/jatin/Desktop/work/bq/credentials.json

# LiveKit RTMP Ingress Configuration
LIVEKIT_RTMP_ENABLED=true  # Enable RTMP ingress (default: true)
LIVEKIT_RTMP_PORT=1935  # RTMP port (default: 1935)

# CORS Configuration
# Comma-separated list of allowed origins (e.g., for ngrok or custom domains)
# Example: CORS_ALLOWED_ORIGINS=https://abc123.ngrok.io,https://yourdomain.com
# Leave empty to use default localhost origins only
CORS_ALLOWED_ORIGINS=
# Set to "true" to allow all origins (use only for development, NOT production)
ALLOW_ALL_ORIGINS=false

# Base URL for QR codes and remote session links
# This should be your public-facing URL (e.g., ngrok URL or production domain)
# Example: BASE_URL=https://abc123.ngrok.io
# Default: http://localhost:3000
BASE_URL=http://localhost:3000


# SendGrid Configuration for Email Verification
# IMPORTANT: You must verify a sender email address in SendGrid dashboard
# Go to: Settings > Sender Authentication > Single Sender Verification
# After verifying, use that email address below
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=your-verified-email@example.com